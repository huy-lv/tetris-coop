# Environment variables for Tetris Server
NODE_ENV=production
SERVER_PORT=3001

# CORS configuration - allow connections from your frontend domain
CORS_ORIGIN=https://your-frontend-domain.com,https://tetris.huytrang.id.vn

# Socket.IO configuration
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# Game configuration
MAX_ROOMS=100
MAX_PLAYERS_PER_ROOM=4

# Logging
LOG_LEVEL=info

# Health check configuration
HEALTH_CHECK_ENABLED=true

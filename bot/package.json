{
  "name": "tetris-browser-bot",
  "version": "1.0.0",
  "description": "Browser automation bot for Tetris multiplayer game",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "bot:create": "tsx src/index.ts --playwright --create-room --debug",
    "bot:join": "tsx src/index.ts --playwright --room ROOM_CODE --debug"
  },
  "keywords": [
    "tetris",
    "bot",
    "puppeteer",
    "automation"
  ],
  "author": "Tetris Bot",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "dotenv": "^16.3.0",
    "playwright": "^1.54.1",
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}

{
  "name": "tetris-browser-bot",
  "version": "1.0.0",
  "description": "Browser automation bot for Tetris multiplayer game",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "bot": "tsx src/index.ts",
    "bot:visible": "tsx src/index.ts test --visible --create-room",
    "bot:playwright": "tsx src/index.ts test --playwright --create-room",
    "bot:new-headless": "tsx src/index.ts test --create-room --debug",
    "bot:watch": "node src/viewer.js",
    "bot:play": "concurrently \"yarn bot:new-headless\" \"sleep 3 && yarn bot:watch\"",
    "bot:visible-alt": "node src/start-visible.js",
    "bot:visible-force": "tsx src/index.ts test --visible --create-room --debug",
    "bot:headless": "tsx src/index.ts test --headless --create-room",
    "bot:debug": "tsx src/index.ts test --visible --debug --create-room",
    "install:deps": "yarn install",
    "test:connection": "tsx src/index.ts test"
  },
  "keywords": [
    "tetris",
    "bot",
    "puppeteer",
    "automation"
  ],
  "author": "Tetris Bot",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "dotenv": "^16.3.0",
    "playwright": "^1.54.1",
    "puppeteer": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
